# Cal.com
CAL_API_KEY=cal_your_key_here
CAL_API_BASE_URL=https://api.cal.com
CAL_DEFAULT_TIMEZONE=America/New_York
CAL_DEFAULT_ATTENDEE_NAME=Xinyu Tu
CAL_DEFAULT_ATTENDEE_EMAIL=you@example.com

# Pick either CAL_EVENT_TYPE_ID or CAL_EVENT_TYPE_SLUG + CAL_USERNAME.
# Event type id is easiest once you know it.
CAL_EVENT_TYPE_ID=
CAL_EVENT_TYPE_SLUG=
CAL_USERNAME=
CAL_ORGANIZATION_SLUG=
# Most Cal.com event types have a fixed length. Keep this false unless the event
# type supports multiple possible lengths.
CAL_SEND_LENGTH_IN_MINUTES=false

# LLM mode. Use openai or openrouter for the real app. rule_based is for tests only.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# OpenRouter mode reads OPENROUTER_* automatically when LLM_PROVIDER=openrouter.
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
