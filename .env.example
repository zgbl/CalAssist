# Cal.com
CAL_API_KEY=cal_your_key_here
CAL_EVENT_TYPE_ID=123

# Final manually tested LLM path: OpenRouter + NVIDIA.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Optional OpenAI path. Code-supported, but not the final manually verified path.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-4o-mini

# Defaults used by the app:
# CAL_DEFAULT_TIMEZONE=America/New_York
# CAL_ALLOW_BOOKING_OUT_OF_BOUNDS=true
# CAL_ALLOW_CONFLICTS=false
